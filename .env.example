# ----------------------------------------------------------------------------
# Cybromines — environment variables
# Copy to `.env.local` for local dev. All are build-time inlined (NEXT_PUBLIC_*).
# ----------------------------------------------------------------------------

# Canonical site origin — used for metadata, canonical URLs, sitemap, OG, RSS.
NEXT_PUBLIC_SITE_URL=https://cybromines.com

# Contact form submission endpoint (e.g. a Formspree URL or your own API).
# If empty, the contact form gracefully falls back to a mailto: link.
NEXT_PUBLIC_CONTACT_ENDPOINT=

# WhatsApp number in international format, digits only (no +, spaces, or dashes).
NEXT_PUBLIC_WHATSAPP_NUMBER=971500000000

# Google Analytics 4 Measurement ID. GA only loads when this is set.
NEXT_PUBLIC_GA_ID=
